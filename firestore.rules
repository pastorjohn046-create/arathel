rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, kycStatus, role, createdAt
    //
    // Collection: assets
    // Fields: symbol, name, price, change24h, type, category
    //
    // Collection: trades
    // Fields: userId, assetId, symbol, type, amount, price, timestamp, status
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "pastorjohn046@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['symbol', 'name', 'price', 'type']) &&
             data.symbol is string && data.symbol.size() < 10 &&
             data.name is string && data.name.size() < 100 &&
             data.price is number && data.price >= 0;
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['userId', 'assetId', 'type', 'amount', 'price']) &&
             data.userId == request.auth.uid &&
             data.type in ['buy', 'sell'] &&
             data.amount is number && data.amount > 0 &&
             data.price is number && data.price > 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && isValidUser(request.resource.data));
    }

    match /assets/{assetId} {
      allow read: if true; // Publicly viewable market data
      allow write: if isAdmin() && isValidAsset(request.resource.data);
    }

    match /trades/{tradeId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidTrade(request.resource.data);
      allow update, delete: if isAdmin(); // Users cannot modify trade history
    }
  }
}
