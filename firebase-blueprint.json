{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user account information and KYC status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "kycStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "assets": {
      "title": "Financial Asset",
      "description": "Stocks, commodities, or crypto assets available for trading.",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "change24h": { "type": "number" },
        "type": { "type": "string", "enum": ["stock", "commodity", "crypto"] },
        "category": { "type": "string" }
      },
      "required": ["symbol", "name", "price", "type"]
    },
    "trades": {
      "title": "Trade Execution",
      "description": "Records of buy/sell transactions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "assetId": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "amount": { "type": "number" },
        "price": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] }
      },
      "required": ["userId", "assetId", "type", "amount", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents."
    },
    "/assets/{assetId}": {
      "schema": "assets",
      "description": "Global asset list."
    },
    "/trades/{tradeId}": {
      "schema": "trades",
      "description": "Transaction history."
    }
  }
}
